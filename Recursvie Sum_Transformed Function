(defun sum_transformed(L f)
  (cond
  ((null L) 0) ;Return 0 if empty
  (t
    (+ (apply f (list (car L)))
      (sum_transformed (cdr L) f))
    );t
  );cond
);defun

(print (sum_transformed '() #'(lambda (x) (* x x)))); => 0 Base Case
(print (sum_transformed '(1 2 3) #'(lambda (x) (* x x)))); => 14
(print (sum_transformed '(2 3 4) #'(lambda (x) (* x x)))); => 29
